from itertools import combinations

def print_combinations_up_to_size(s, k):
    
    sorted_s = sorted(s)
    
   
    for size in range(1, k + 1):
        
        for combo_tuple in combinations(sorted_s, size):
            
            combo_str = "".join(combo_tuple)
            
            print(combo_str)

input_line = input()

try:
    s_val, k_val_str = input_line.split()
    k_val = int(k_val_str)
    
    
    print_combinations_up_to_size(s_val, k_val)
except ValueError:
    print("Invalid input format. Please provide a string and an integer separated by a space.")

