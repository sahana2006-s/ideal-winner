def average(arr):
    """
    Computes the average of unique elements in an array.

    Args:
        arr: A list or array of numbers.

    Returns:
        The average of distinct elements as a float.
    """
    # Convert the array to a set to get distinct heights
    distinct_heights = set(arr)
    
    # Calculate the sum of distinct heights
    sum_of_heights = sum(distinct_heights)
    
    # Calculate the number of distinct heights
    count_of_heights = len(distinct_heights)
    
    # Compute the average
    avg = sum_of_heights / count_of_heights
    
    # The problem description and sample output imply a need for high precision,
    # but the instructions ask for a float return type. 
    # Standard Python floats handle this naturally.
    return avg
