def print_formatted(number):
    width = len(bin(number)[2:])
    for i in range(1, number + 1):
        # {i:>{width}d}: Decimal
        # {i:>{width}o}: Octal
        # {i:>{width}X}: Hexadecimal (capitalized)
        # {i:>{width}b}: Binary
        print(f"{i:>{width}d} {i:>{width}o} {i:>{width}X} {i:>{width}b}")
