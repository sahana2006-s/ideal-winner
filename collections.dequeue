from collections import deque
import sys


n = int(sys.stdin.readline())


d = deque()


for _ in range(n):
    line = sys.stdin.readline().split()
    method = line[0]
    
    if len(line) > 1:
        
        value = line[1]
        getattr(d, method)(value)
    else:
        
        getattr(d, method)()


print(*(d))
